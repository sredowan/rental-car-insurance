RewriteEngine On
DirectorySlash Off
RewriteBase /api/

# Block access to PHP config files directly
RewriteRule ^config/ - [F,L]

# Block access to middleware/helpers directly
RewriteRule ^middleware/ - [F,L]
RewriteRule ^helpers/ - [F,L]

# Route everything to index.php (even if it's a directory like /quotes)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.*)$ index.php [QSA,L]
